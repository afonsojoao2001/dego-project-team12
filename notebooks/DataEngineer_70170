## 2b — Inconsistent Date Formats
import re

# Detect which format each date_of_birth uses
def detect_date_format(val):
    if pd.isna(val):
        return 'missing'
    val = str(val)
    if re.match(r'^\d{4}-\d{2}-\d{2}$', val):
        return 'YYYY-MM-DD (ISO)'
    if re.match(r'^\d{4}/\d{2}/\d{2}$', val):
        return 'YYYY/MM/DD'
    if re.match(r'^\d{2}/\d{2}/\d{4}$', val):
        return 'DD/MM/YYYY'
    if re.match(r'^\d{2}-\d{2}-\d{4}$', val):
        return 'DD-MM-YYYY'
    return 'unknown'

df_clean = df_clean.copy()
df_clean['dob_format'] = df_clean['date_of_birth'].apply(detect_date_format)

print('date_of_birth format distribution:')
print(df_clean['dob_format'].value_counts())

# Show non-ISO rows
non_iso = df_clean[df_clean['dob_format'] != 'YYYY-MM-DD (ISO)']
if not non_iso.empty:
    print(f'\nNon-ISO dates ({len(non_iso)} rows):')
    display(non_iso[['_id', 'full_name', 'date_of_birth', 'dob_format']])

# ── Remediation: normalize all dates to ISO YYYY-MM-DD ────────────────────────
def normalize_date(val):
    """Try multiple formats; return ISO string or NaT."""
    if pd.isna(val):
        return pd.NaT
    for fmt in ('%Y-%m-%d', '%Y/%m/%d', '%d/%m/%Y', '%d-%m-%Y', '%m/%d/%Y'):
        try:
            return datetime.strptime(str(val), fmt).date().isoformat()
        except ValueError:
            continue
    return pd.NaT  # Could not parse → flag as missing

df_clean['date_of_birth_norm'] = df_clean['date_of_birth'].apply(normalize_date)

# How many could NOT be parsed?
still_broken = df_clean['date_of_birth_norm'].isna().sum()
print(f'Dates successfully normalized: {(~df_clean["date_of_birth_norm"].isna()).sum()}')
print(f'Dates still unparseable (NaT): {still_broken}')


