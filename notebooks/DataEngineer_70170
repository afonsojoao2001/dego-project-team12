## Setup & Data Loading
import json
import pandas as pd
import numpy as np
from datetime import datetime, date

# ── Load raw JSON ──────────────────────────────────────────────────────────────
with open('../data/raw_credit_applications.json', 'r') as f:
    raw = json.load(f)

# ── Flatten nested structure into a flat DataFrame ────────────────────────────
records = []
for entry in raw:
    record = {
        '_id': entry.get('_id'),
        # applicant_info
        'full_name':            entry.get('applicant_info', {}).get('full_name'),
        'email':                entry.get('applicant_info', {}).get('email'),
        'ssn':                  entry.get('applicant_info', {}).get('ssn'),
        'gender':               entry.get('applicant_info', {}).get('gender'),
        'date_of_birth':        entry.get('applicant_info', {}).get('date_of_birth'),
        'zip_code':             entry.get('applicant_info', {}).get('zip_code'),
        # financials
        'annual_income':        entry.get('financials', {}).get('annual_income'),
        'credit_history_months':entry.get('financials', {}).get('credit_history_months'),
        'debt_to_income':       entry.get('financials', {}).get('debt_to_income'),
        'savings_balance':      entry.get('financials', {}).get('savings_balance'),
        # decision
        'loan_approved':        entry.get('decision', {}).get('loan_approved'),
    }
    records.append(record)

df = pd.DataFrame(records)
print(f'Rows: {len(df)}  |  Columns: {len(df.columns)}')
df.head()

##1 - UNIQUENESS
# 1a - Exact Duplicate Rows
# Exact duplicates: every column is identical (including _id)
exact_dupes = df[df.duplicated(keep=False)]

print(f'Exact duplicate rows found: {len(exact_dupes)}')

if not exact_dupes.empty:
    display(exact_dupes.sort_values('_id'))


# 1b — Logical Duplicates via SSN
# Same SSN → same person, different _id
ssn_dupes = df[df.duplicated(subset=['ssn'], keep=False)]

print(f'Rows with a duplicate SSN: {len(ssn_dupes)}')

if not ssn_dupes.empty:
    display(
        ssn_dupes[['_id', 'full_name', 'ssn', 'date_of_birth']]
        .sort_values('ssn')
    )

# 1c - Logical Duplicates via Name + Date of Birth
# Same full_name AND date_of_birth → almost certainly the same person
name_dob_dupes = df[df.duplicated(subset=['full_name', 'date_of_birth'], keep=False)]

print(f'Rows with duplicate name + DOB: {len(name_dob_dupes)}')

if not name_dob_dupes.empty:
    display(
        name_dob_dupes[['_id', 'full_name', 'ssn', 'date_of_birth']]
        .sort_values(['full_name', 'date_of_birth'])
    )

#1d — Remediation: Remove Duplicates (Strategy: keep the first occurrence, drop the rest.)
before = len(df)

df_clean = df.drop_duplicates(keep='first')

df_clean = df_clean.drop_duplicates(subset=['ssn'], keep='first')

df_clean = df_clean.drop_duplicates(subset=['full_name', 'date_of_birth'], keep='first')

after = len(df_clean)
print(f'Rows before: {before}  →  after dedup: {after}  ({before - after} removed)')

