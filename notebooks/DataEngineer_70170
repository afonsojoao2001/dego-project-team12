# ── Impossible ages (< 18 or > 120 years) ─────────────────────────────────────
today = date.today()

def calc_age(dob_str):
    try:
        dob = date.fromisoformat(str(dob_str))
        return (today - dob).days // 365
    except Exception:
        return np.nan

df_clean['age'] = df_clean['date_of_birth_norm'].apply(calc_age)

impossible_age = df_clean[(df_clean['age'] < 18) | (df_clean['age'] > 120)]
print(f'Impossible ages (< 18 or > 120): {len(impossible_age)}')
if not impossible_age.empty:
    display(impossible_age[['_id', 'full_name', 'date_of_birth', 'date_of_birth_norm', 'age']])

# ── Debt-to-income ratio > 1.0 (100%) ─────────────────────────────────────────
dti_over = df_clean[pd.to_numeric(df_clean['debt_to_income'], errors='coerce') > 1.0]
print(f'DTI > 1.0: {len(dti_over)}')
if not dti_over.empty:
    display(dti_over[['_id', 'full_name', 'debt_to_income']])

## 2d - Inconsistent Categorical Coding (gender)
# What values exist?
print('gender — raw value counts:')
print(df_clean['gender'].value_counts(dropna=False))

# ── Remediation: normalize to 'Male' / 'Female' / 'Other' / 'Unknown' ─────────
GENDER_MAP = {
    # Male variants
    'male': 'Male', 'm': 'Male', 'man': 'Male',
    # Female variants
    'female': 'Female', 'f': 'Female', 'fem.': 'Female', 'woman': 'Female',
    # Non-binary / other
    'non-binary': 'Other', 'nonbinary': 'Other', 'nb': 'Other',
    'prefer not to say': 'Unknown',
}

def normalize_gender(val):
    if pd.isna(val):
        return 'Unknown'
    return GENDER_MAP.get(str(val).strip().lower(), val)  # keep original if not in map

df_clean['gender_norm'] = df_clean['gender'].apply(normalize_gender)

print('gender — normalized value counts:')
print(df_clean['gender_norm'].value_counts(dropna=False))

# Show rows that still could not be mapped
still_weird = df_clean[~df_clean['gender_norm'].isin(['Male', 'Female', 'Other', 'Unknown'])]
if not still_weird.empty:
    print('\nRows with unrecognized gender value:')
    display(still_weird[['_id', 'full_name', 'gender', 'gender_norm']])

